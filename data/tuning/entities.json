{
  "player": {
    "mass": 1,
    "max_health": 100,
    "collision_objects": [{ "type": "circle", "radius": 20 }],
    "admin": {
      "name": "Player",
      "spawnable": true,
      "fields": [
        { "attribute": "transform.position", "label": "Position", "input": "position", "scope": "edit", "default": "[0,0]", "min": -3000, "max": 3000, "step": 1 },
        { "attribute": "player.name", "label": "Name", "input": "text", "scope": "both", "default": "Training Player", "max_length": 20 },
        { "attribute": "player.class", "label": "Class", "input": "select", "scope": "spawn", "default": "gunslinger", "options": [{ "value": "gunslinger", "label": "Gunslinger" }, { "value": "mage", "label": "Mage" }] },
        { "attribute": "player.speed_multiplier", "label": "Movement speed", "input": "number", "scope": "both", "default": "1", "min": 0.25, "max": 4, "step": 0.25 },
        { "attribute": "player.view_distance", "label": "View distance", "input": "number", "scope": "edit", "default": "1200", "min": 300, "max": 2000, "step": 100 },
        { "attribute": "physics.mass", "label": "Mass", "input": "number", "scope": "edit", "default": "1", "min": -1, "max": 1000, "step": 0.25 },
        { "attribute": "vitals.health", "label": "Health", "input": "number", "scope": "edit", "default": "100", "min": -1, "max": 10000, "step": 1 },
        { "attribute": "vitals.max_health", "label": "Maximum health", "input": "number", "scope": "edit", "default": "100", "min": -1, "max": 10000, "step": 1 }
      ]
    }
  },
  "projectile": {
