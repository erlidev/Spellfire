        { "attribute": "render.element", "label": "Element", "input": "select", "scope": "both", "default": "none", "options": [{ "value": "none", "label": "None" }, { "value": "fire", "label": "Fire" }, { "value": "frost", "label": "Frost" }, { "value": "storm", "label": "Storm" }, { "value": "arcane", "label": "Arcane" }, { "value": "earth", "label": "Earth" }] },
        { "attribute": "transform.heading_degrees", "label": "Heading", "input": "rotation", "scope": "both", "default": "0", "min": -180, "max": 180, "step": 1 },
        { "attribute": "transform.position", "label": "Position", "input": "position", "scope": "edit", "default": "[0,0]", "min": -3000, "max": 3000, "step": 1 },
        { "attribute": "physics.mass", "label": "Mass", "input": "number", "scope": "edit", "default": "0", "min": -1, "max": 1000, "step": 0.25 },
        { "attribute": "vitals.health", "label": "Health", "input": "number", "scope": "edit", "default": "-1", "min": -1, "max": 10000, "step": 1 }
      ]
    }
  },
